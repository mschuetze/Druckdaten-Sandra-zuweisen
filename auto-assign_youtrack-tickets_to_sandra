const entities = require('@jetbrains/youtrack-scripting-api/entities');

exports.rule = entities.Issue.onChange({
    title: 'Auto-Assign bei Approved + Supplier Match (Multi-User)',

    guard: (ctx) => {
        const issue = ctx.issue;
        const allowedValues = ["Pollinger", "Wir machen Druck", "Caesar Events USA"];

        const isApproved = issue.fields.becomes(ctx.State, ctx.State.Approved);
        const supplier = issue.fields.Supplier;
        const supplierMatch = supplier && allowedValues.includes(supplier.name);

        return isApproved && supplierMatch;
    },

    action: (ctx) => {
        const issue = ctx.issue;
        const loginSandra = "Sandra_Schalk";
        const sandra = entities.User.findByLogin(loginSandra);

        if (sandra) {
            // Wir sammeln die Logins der aktuellen Assignees für die Erwähnung
            const existingAssignees = [];
            issue.fields.Assignee.forEach(user => {
                if (user.login !== loginSandra) {
                    existingAssignees.push("@" + user.login);
                }
            });
            // Kommentar erstellen
            if (existingAssignees.length > 0) {
                const mentionText = existingAssignees.join(", ");
                issue.addComment("Hallo " + mentionText + "! Bitte noch die Druckdaten erstellen. Sandra wurde bereits automatisch dem Ticket hinzugefügt.");
            } 
            else {
            }
            // User hinzufügen
            issue.fields.Assignee.add(sandra);
            console.log("Sandra_Schalk wurde dem Ticket hinzugefügt.");
        } 
        else {
            console.warn("Sandra_Schalk wurde nicht gefunden.");
        }
    },

    requirements: {
        State: {
            type: entities.State.fieldType,
            Approved: {}
        },
        Supplier: {
            type: entities.EnumField.fieldType
        },
        Assignee: {
            type: entities.User.fieldType,
            multi: true 
        }
    }
});