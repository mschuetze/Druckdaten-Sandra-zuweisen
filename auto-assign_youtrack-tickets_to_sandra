// v1.0.0

const entities = require('@jetbrains/youtrack-scripting-api/entities');

exports.rule = entities.Issue.onChange({
  title: 'Auto-Assign bei Approved + Supplier Match (Multi-User)',

  guard: (ctx) => {
    const issue = ctx.issue;
    const allowedValues = ["Pollinger", "Wir machen Druck", "Caesar Events USA"];

    const isApproved = issue.fields.becomes(ctx.State, ctx.State.Approved);
    const supplier = issue.fields.Supplier;
    const supplierMatch = supplier && allowedValues.includes(supplier.name);

    return isApproved && supplierMatch;
  },

  action: (ctx) => {
    const issue = ctx.issue;
    const user = entities.User.findByLogin("Sandra_Schalk");

    if (user) {
      // Das Feld komplett leeren
      issue.fields.Assignee.clear();
      // User hinzufügen
      issue.fields.Assignee.add(user);
      console.log("Assignee bereinigt und auf Sandra_Schalk gesetzt.");
    } else {
      console.warn("Sandra_Schalk wurde nicht gefunden.");
    }
  },

  requirements: {
    State: {
      type: entities.State.fieldType,
      Approved: {}
    },
    Supplier: {
      type: entities.EnumField.fieldType
    },
    Assignee: {
      type: entities.User.fieldType,
      multi: true 
    }
  }
});